# ─── Sanity CMS (Studio at /studio) ──────────────────────────────────────────
# Only required if you use the Sanity Studio editor (/studio route).
# The main site reads content from cms/*.json and works without these.
#
# 1. Create a free project at https://sanity.io/manage
# 2. Copy your Project ID and dataset name below.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Contact Form (Formspree) ─────────────────────────────────────────────────
# Required to receive submissions from the contact form.
#
# 1. Create a free account at https://formspree.io
# 2. Click "New Form", name it (e.g. "Сайт — заявка"), and copy the form ID.
#    The ID is the last segment of the URL shown: https://formspree.io/f/{FORM_ID}
# 3. Paste it below. Formspree will forward submissions to your email.
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here
